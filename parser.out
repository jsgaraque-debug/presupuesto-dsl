    POR             reduce using rule 16 (expresion -> expresion DIVIDIDO expresion .)
    DIVIDIDO        reduce using rule 16 (expresion -> expresion DIVIDIDO expresion .)
    PUNTO_Y_COMA    reduce using rule 16 (expresion -> expresion DIVIDIDO expresion .)
    PAR_DER         reduce using rule 16 (expresion -> expresion DIVIDIDO expresion .)
    ENTONCES        reduce using rule 16 (expresion -> expresion DIVIDIDO expresion .)

  ! MAS             [ shift and go to state 23 ]
  ! MENOS           [ shift and go to state 24 ]
  ! POR             [ shift and go to state 25 ]
  ! DIVIDIDO        [ shift and go to state 26 ]


state 38

    (17) expresion -> PAR_IZQ expresion PAR_DER .

    MAYOR           reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    MENOR           reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    IGUAL           reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    MAS             reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    MENOS           reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    POR             reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    DIVIDIDO        reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    PUNTO_Y_COMA    reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    PAR_DER         reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)
    ENTONCES        reduce using rule 17 (expresion -> PAR_IZQ expresion PAR_DER .)


state 39

    (9) llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER . PUNTO_Y_COMA

    PUNTO_Y_COMA    shift and go to state 40


state 40

    (9) llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER PUNTO_Y_COMA .

    ID              reduce using rule 9 (llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER PUNTO_Y_COMA .)
    SI              reduce using rule 9 (llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER PUNTO_Y_COMA .)
    CALCULAR_IMPUESTO reduce using rule 9 (llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER PUNTO_Y_COMA .)
    $end            reduce using rule 9 (llamada_funcion -> CALCULAR_IMPUESTO PAR_IZQ expresion PAR_DER PUNTO_Y_COMA .)

